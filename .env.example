# Application
NEXTAUTH_URL=http://localhost:5174
NEXTAUTH_SECRET=change-me-to-a-random-string
AUTH_COOKIE_DOMAIN=localhost

# Database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
